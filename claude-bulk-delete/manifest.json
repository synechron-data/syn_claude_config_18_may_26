/* ============================================================
   FILE: manifest.json
   Claude Bulk Delete — Chrome Extension (Manifest V3)
   ============================================================ */
{
  "manifest_version": 3,
  "name": "Claude Bulk Delete",
  "version": "1.0.0",
  "description": "Add bulk-select and bulk-delete functionality to the claude.ai conversation sidebar.",
  "permissions": [],
  "host_permissions": [
    "https://claude.ai/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Claude Bulk Delete"
  }
}
