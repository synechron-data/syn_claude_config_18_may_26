# Environment Variables — Demo Project
# Copy this file to .env and fill in values before running locally.
# NEVER commit .env to Git. It is in .gitignore.

# Server
PORT=3000
NODE_ENV=development

# JWT Configuration
JWT_SECRET=replace-with-a-long-random-secret-minimum-32-characters
JWT_EXPIRES_IN=1h
REFRESH_EXPIRES_IN=7d

# Logging
LOG_LEVEL=info
